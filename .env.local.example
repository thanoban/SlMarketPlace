# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
# Get from: MongoDB Atlas → Connect → Drivers → Node.js connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/slevents?retryWrites=true&w=majority

# ─── NextAuth.js ─────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
# Local development URL (change to your Vercel URL in production)
NEXTAUTH_URL=http://localhost:3000

# ─── Cloudinary ──────────────────────────────────────────────────────────────
# Get from: Cloudinary Dashboard → Settings → API Keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Event Scraper ───────────────────────────────────────────────────────────
# Generate cron secret: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here
# Eventbrite public API token — get free at: https://www.eventbrite.com/platform/api-keys
EVENTBRITE_API_KEY=your-eventbrite-token-here
# ObjectId of the UniPlaza Bot club — copy from output of: npm run seed:bot
BOT_CLUB_ID=paste-bot-club-id-here
